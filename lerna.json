{
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "publish": {
    "allowBranch": "master",
    "message": "chore(release): Publish",
    "ignoreChanges": ["CHANGELOG.md", "**/__tests__/**", "**/__mocks__/**"]
  },
  "command": {
    "version": {
      "conventionalCommits": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "version": "independent"
}
